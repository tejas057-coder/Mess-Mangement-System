# ══════════════════════════════════════════════
#  Mess Management System — Root .gitignore
#  Covers both /frontend and /backend
# ══════════════════════════════════════════════

# ── Dependencies ──────────────────────────────
**/node_modules/

# ── Environment / secrets ─────────────────────
**/.env
**/.env.local
**/.env.*.local

# ── Production builds ─────────────────────────
frontend/dist/
frontend/build/

# ── Logs ─────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── SQLite / database files ───────────────────
*.db
*.sqlite
*.sqlite3

# ── OS files ─────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ── Editor / IDE ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.user

# ── Vite / build tooling cache ────────────────
**/.vite/
**/.cache/
**/coverage/

# ── Antigravity / AI agent files ─────────────
.agents/

# ── Package lock files (optional: keep for reproducibility) ──
# Uncomment below to ignore lock files:
# package-lock.json
# yarn.lock
# pnpm-lock.yaml
